@model ContactViewModel

<section class="py-5">
    <div class="container">
        @await Html.PartialAsync("~/Views/Shared/Partials/_Breadcrumbs.cshtml", Model.Breadcrumbs)
        <div class="row g-5">
            <div class="col-lg-5">
                <span class="eyebrow text-primary">Liên hệ tư vấn</span>
                <h1>@Model.Title</h1>
                <p class="page-subtitle">@Model.Subtitle</p>
                <div class="panel-card mt-4">
                    <div class="detail-grid">
                        <div class="detail-item"><span>Hotline</span><strong>0901 001 001</strong></div>
                        <div class="detail-item"><span>Email</span><strong>hello@northstarenglish.vn</strong></div>
                        <div class="detail-item"><span>Địa chỉ</span><strong>120 Nguyễn Văn Linh, Đà Nẵng</strong></div>
                        <div class="detail-item"><span>Ca tư vấn</span><strong>08:00 - 20:30</strong></div>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="panel-card">
                    <div class="panel-card-header"><div><h3>Đăng ký tư vấn</h3><p>Form này đang là mock flow, chưa lưu database.</p></div></div>
                    <form asp-action="Index" method="post" class="row g-4">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label"></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Topic" class="form-label"></label>
                            <select asp-for="Topic" class="form-select">
                                <option value="">Chọn nhu cầu</option>
                                <option>TOEIC</option>
                                <option>IELTS</option>
                                <option>Giao tiếp</option>
                                <option>Tư vấn xếp lớp</option>
                            </select>
                            <span asp-validation-for="Topic" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Message" class="form-label"></label>
                            <textarea asp-for="Message" rows="5" class="form-control"></textarea>
                            <span asp-validation-for="Message" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <button class="btn btn-primary" type="submit">Gửi yêu cầu</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
