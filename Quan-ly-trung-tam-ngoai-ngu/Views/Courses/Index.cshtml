@model CourseCatalogPageViewModel

<section class="py-5">
    <div class="container">
        @await Html.PartialAsync("~/Views/Shared/Partials/_Breadcrumbs.cshtml", Model.Breadcrumbs)
        <div class="section-heading">
            <div>
                <span class="eyebrow text-primary">Danh mục đào tạo</span>
                <h1>@Model.Title</h1>
                <p class="page-subtitle">@Model.Subtitle</p>
            </div>
        </div>
        <div class="toolbar-row mb-4">
            <div class="toolbar-search">
                <i class="bi bi-search"></i>
                <input type="text" class="form-control" placeholder="Tìm kiếm khóa học..." />
            </div>
            <div class="toolbar-filters">
                @foreach (var filter in Model.Filters)
                {
                    <select class="form-select">
                        <option>@filter.Label</option>
                        @foreach (var option in filter.Options)
                        {
                            <option value="@option.Value">@option.Label</option>
                        }
                    </select>
                }
            </div>
        </div>
        <div class="row g-4">
            @foreach (var course in Model.Courses)
            {
                <div class="col-lg-4">
                    <article class="feature-card h-100">
                        <span class="badge @AppUi.StatusBadgeClass(course.Status)">@course.Status</span>
                        <h3>@course.Name</h3>
                        <p>@course.ShortDescription</p>
                        <ul class="feature-list">
                            <li><i class="bi bi-bar-chart"></i>@course.Level</li>
                            <li><i class="bi bi-calendar2-week"></i>@course.Duration</li>
                            <li><i class="bi bi-cash-coin"></i>@AppUi.Currency(course.TuitionFee)</li>
                        </ul>
                        <div class="text-muted small mb-3">Khai giảng dự kiến: @course.NextOpening</div>
                        <a class="btn btn-primary w-100" asp-action="Details" asp-route-id="@course.Slug">Xem chi tiết</a>
                    </article>
                </div>
            }
        </div>
    </div>
</section>
