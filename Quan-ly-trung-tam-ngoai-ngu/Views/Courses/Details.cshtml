@model CourseDetailPageViewModel

<section class="py-5">
    <div class="container">
        @await Html.PartialAsync("~/Views/Shared/Partials/_Breadcrumbs.cshtml", Model.Breadcrumbs)
        <div class="row g-5">
            <div class="col-lg-8">
                <span class="badge @AppUi.StatusBadgeClass(Model.Course.Status) mb-3">@Model.Course.Status</span>
                <h1>@Model.Course.Name</h1>
                <p class="page-subtitle">@Model.Description</p>
                <div class="row g-3 mb-4">
                    <div class="col-md-4"><div class="detail-box"><span>Trình độ</span><strong>@Model.Course.Level</strong></div></div>
                    <div class="col-md-4"><div class="detail-box"><span>Thời lượng</span><strong>@Model.Course.Duration</strong></div></div>
                    <div class="col-md-4"><div class="detail-box"><span>Học phí</span><strong>@AppUi.Currency(Model.Course.TuitionFee)</strong></div></div>
                </div>
                <div class="panel-card mb-4">
                    <div class="panel-card-header"><div><h3>Mục tiêu khóa học</h3><p>@Model.TargetOutput</p></div></div>
                    <ul class="feature-list">
                        @foreach (var item in Model.Objectives)
                        {
                            <li><i class="bi bi-check2-circle"></i>@item</li>
                        }
                    </ul>
                </div>
                <div class="panel-card">
                    <div class="panel-card-header"><div><h3>Điểm nổi bật</h3><p>Những tiện ích học viên nhận được trong lộ trình này.</p></div></div>
                    <ul class="feature-list">
                        @foreach (var item in Model.Highlights)
                        {
                            <li><i class="bi bi-stars"></i>@item</li>
                        }
                    </ul>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="panel-card mb-4">
                    <div class="panel-card-header"><div><h3>Thông tin nhanh</h3><p>Tóm tắt để học viên ra quyết định.</p></div></div>
                    <div class="detail-grid">
                        <div class="detail-item"><span>Lịch học</span><strong>@Model.Course.ScheduleSummary</strong></div>
                        <div class="detail-item"><span>Khai giảng</span><strong>@Model.Course.NextOpening</strong></div>
                        <div class="detail-item"><span>CTA</span><strong><a asp-controller="Contact" asp-action="Index">Đăng ký tư vấn</a></strong></div>
                    </div>
                </div>
                <div class="panel-card">
                    <div class="panel-card-header"><div><h3>Lớp học liên quan</h3><p>Các lớp đang mở cho khóa này.</p></div></div>
                    <div class="list-group list-group-flush panel-list">
                        @foreach (var classItem in Model.RelatedClasses)
                        {
                            <div class="list-group-item">
                                <strong>@classItem.Code</strong>
                                <div class="small text-muted">@classItem.Schedule</div>
                                <span class="badge @AppUi.StatusBadgeClass(classItem.Status) mt-2">@classItem.Status</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
