@model HomePageViewModel

<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-7">
                <span class="eyebrow">Đồ án quản lý trung tâm ngoại ngữ</span>
                <h1>@Model.HeroTitle</h1>
                <p class="hero-copy">@Model.HeroSubtitle</p>
                <div class="d-flex flex-wrap gap-3">
                    <a class="btn btn-warning btn-lg" asp-controller="Courses" asp-action="Index">Xem khóa học</a>
                    <a class="btn btn-outline-light btn-lg" asp-controller="Contact" asp-action="Index">Đăng ký tư vấn</a>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="hero-panel">
                    <div class="hero-panel-badge"><i class="bi bi-stars me-2"></i>Frontend skeleton sẵn sàng demo</div>
                    <div class="hero-panel-grid">
                        @foreach (var stat in Model.HighlightStats)
                        {
                            <div class="hero-mini-card">
                                <span>@stat.Title</span>
                                <strong>@stat.Value</strong>
                                <small>@stat.Description</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="section-heading">
            <div>
                <span class="eyebrow text-primary">Khóa học nổi bật</span>
                <h2>Lộ trình rõ ràng cho TOEIC, IELTS và giao tiếp</h2>
            </div>
            <a class="btn btn-outline-primary" asp-controller="Courses" asp-action="Index">Tất cả khóa học</a>
        </div>
        <div class="row g-4">
            @foreach (var course in Model.FeaturedCourses)
            {
                <div class="col-lg-4">
                    <article class="feature-card h-100">
                        <span class="badge @AppUi.StatusBadgeClass(course.Status)">@course.Status</span>
                        <h3>@course.Name</h3>
                        <p>@course.ShortDescription</p>
                        <ul class="feature-list">
                            <li><i class="bi bi-bar-chart"></i>@course.Level</li>
                            <li><i class="bi bi-clock-history"></i>@course.Duration</li>
                            <li><i class="bi bi-cash-coin"></i>@AppUi.Currency(course.TuitionFee)</li>
                        </ul>
                        <a class="btn btn-link px-0" asp-controller="Courses" asp-action="Details" asp-route-id="@course.Slug">Xem chi tiết <i class="bi bi-arrow-right"></i></a>
                    </article>
                </div>
            }
        </div>
    </div>
</section>

<section class="py-5 bg-soft">
    <div class="container">
        <div class="section-heading">
            <div>
                <span class="eyebrow text-primary">Lớp học đang mở</span>
                <h2>Lịch học linh hoạt cho sinh viên và người đi làm</h2>
            </div>
            <a class="btn btn-outline-primary" asp-controller="Classes" asp-action="Index">Xem lịch lớp</a>
        </div>
        <div class="row g-4">
            @foreach (var classItem in Model.OpenClasses)
            {
                <div class="col-lg-4">
                    <div class="schedule-card h-100">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h3>@classItem.Code</h3>
                                <p class="mb-0 text-secondary">@classItem.CourseName</p>
                            </div>
                            <span class="badge @AppUi.StatusBadgeClass(classItem.Status)">@classItem.Status</span>
                        </div>
                        <div class="schedule-meta"><i class="bi bi-person-workspace"></i>@classItem.TeacherName</div>
                        <div class="schedule-meta"><i class="bi bi-clock"></i>@classItem.Schedule</div>
                        <div class="schedule-meta"><i class="bi bi-door-open"></i>@classItem.Room</div>
                        <div class="schedule-meta"><i class="bi bi-calendar-event"></i>Khai giảng: @classItem.StartDate.ToString("dd/MM/yyyy")</div>
                        <div class="seat-pill mt-3">Còn @classItem.SeatsLeft chỗ</div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="section-heading">
            <div>
                <span class="eyebrow text-primary">Tin tức mới</span>
                <h2>Cập nhật thông báo, workshop và kinh nghiệm học tập</h2>
            </div>
            <a class="btn btn-outline-primary" asp-controller="News" asp-action="Index">Xem tất cả</a>
        </div>
        <div class="row g-4">
            @foreach (var article in Model.LatestNews)
            {
                <div class="col-lg-4">
                    <article class="news-card h-100">
                        <div class="news-card-meta">
                            <span>@article.Category</span>
                            <span>@article.PublishedOn.ToString("dd/MM/yyyy")</span>
                        </div>
                        <h3>@article.Title</h3>
                        <p>@article.Summary</p>
                        <a class="btn btn-link px-0" asp-controller="News" asp-action="Details" asp-route-id="@article.Slug">Đọc bài viết <i class="bi bi-arrow-right"></i></a>
                    </article>
                </div>
            }
        </div>
    </div>
</section>
