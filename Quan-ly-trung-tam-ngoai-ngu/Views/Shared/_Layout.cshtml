<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NorthStar English Center</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Quan_ly_trung_tam_ngoai_ngu.styles.css" asp-append-version="true" />
</head>
<body class="app-body">
    <header class="site-header sticky-top">
        <nav class="navbar navbar-expand-lg navbar-dark border-bottom border-white border-opacity-10">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-3" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark"><i class="bi bi-mortarboard-fill"></i></span>
                    <span>
                        <strong>NorthStar English</strong>
                        <small>Quản lý trung tâm ngoại ngữ</small>
                    </span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav mx-auto gap-lg-2">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="About" asp-action="Index">Giới thiệu</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Courses" asp-action="Index">Khóa học</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Classes" asp-action="Index">Lớp học</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="News" asp-action="Index">Tin tức</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Contact" asp-action="Index">Liên hệ</a></li>
                    </ul>
                    <div class="d-flex flex-wrap gap-2">
                        @if (Context.Session.GetString("DemoUserRole") is not null)
                        {
                            <a class="btn btn-light btn-sm" asp-controller="Profile" asp-action="Index"><i class="bi bi-person-circle me-2"></i>Hồ sơ</a>
                            <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Logout">Đăng xuất</a>
                        }
                        else
                        {
                            <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            <a class="btn btn-warning btn-sm" asp-controller="Account" asp-action="Register">Đăng ký</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="row g-4 align-items-center">
                <div class="col-lg-6">
                    <h5>NorthStar English Center</h5>
                    <p class="mb-0 text-secondary">Frontend skeleton cho đồ án “Xây dựng hệ thống website quản lý trung tâm ngoại ngữ”. Tập trung UI/UX, module nghiệp vụ và điều hướng sẵn sàng để nối backend sau.</p>
                </div>
                <div class="col-lg-6 text-lg-end">
                    <div class="footer-meta">Địa chỉ mock: 120 Nguyễn Văn Linh, Đà Nẵng</div>
                    <div class="footer-meta">Hotline mock: 0901 001 001</div>
                    <div class="footer-meta">Email: hello@northstarenglish.vn</div>
                </div>
            </div>
        </div>
    </footer>

    @await Html.PartialAsync("~/Views/Shared/Partials/_Toast.cshtml")
    @await Html.PartialAsync("~/Views/Shared/Partials/_ConfirmModal.cshtml")

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
