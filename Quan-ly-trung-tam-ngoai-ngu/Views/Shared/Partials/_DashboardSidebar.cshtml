@{
    var area = (ViewContext.RouteData.Values["area"]?.ToString() ?? "").ToLowerInvariant();
}
<div class="sidebar-brand">
    <span class="brand-mark"><i class="bi bi-buildings-fill"></i></span>
    <div>
        <strong>NorthStar</strong>
        <small>Language Center</small>
    </div>
</div>
<div class="sidebar-section">Điều hướng</div>
<nav class="sidebar-nav">
    @if (area == "admin")
    {
        <a href="/Admin"><i class="bi bi-grid-1x2-fill"></i><span>Tổng quan</span></a>
        <a href="/Admin/Accounts"><i class="bi bi-people"></i><span>Tài khoản</span></a>
        <a href="/Admin/Students"><i class="bi bi-person-lines-fill"></i><span>Học viên</span></a>
        <a href="/Admin/Teachers"><i class="bi bi-person-video3"></i><span>Giáo viên</span></a>
        <a href="/Admin/Courses"><i class="bi bi-journal-text"></i><span>Khóa học</span></a>
        <a href="/Admin/Classes"><i class="bi bi-easel2"></i><span>Lớp học</span></a>
        <a href="/Admin/Enrollments"><i class="bi bi-journal-check"></i><span>Ghi danh</span></a>
        <a href="/Admin/Receipts"><i class="bi bi-receipt-cutoff"></i><span>Học phí</span></a>
        <a href="/Admin/Sessions"><i class="bi bi-calendar-week"></i><span>Buổi học</span></a>
        <a href="/Admin/Attendance"><i class="bi bi-list-check"></i><span>Điểm danh</span></a>
        <a href="/Admin/Exams"><i class="bi bi-clipboard2-data"></i><span>Điểm số</span></a>
        <a href="/Admin/Reports"><i class="bi bi-bar-chart-line"></i><span>Báo cáo</span></a>
    }
    else if (area == "staff")
    {
        <a href="/Staff"><i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span></a>
        <a href="/Staff/Students"><i class="bi bi-person-lines-fill"></i><span>Học viên</span></a>
        <a href="/Staff/Enrollments"><i class="bi bi-journal-check"></i><span>Ghi danh</span></a>
        <a href="/Staff/Classes"><i class="bi bi-diagram-3"></i><span>Xếp lớp</span></a>
        <a href="/Staff/Receipts"><i class="bi bi-receipt"></i><span>Thu học phí</span></a>
    }
    else
    {
        <a href="/Teacher"><i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span></a>
        <a href="/Teacher/Classes"><i class="bi bi-easel2"></i><span>Lớp được phân công</span></a>
        <a href="/Teacher/Attendance"><i class="bi bi-list-check"></i><span>Điểm danh</span></a>
        <a href="/Teacher/Exams"><i class="bi bi-pencil-square"></i><span>Nhập điểm</span></a>
        <a href="/Teacher/Schedule"><i class="bi bi-calendar-week"></i><span>Lịch dạy</span></a>
    }
</nav>
